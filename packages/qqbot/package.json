{
  "name": "@untiny/chat-adapter-qqbot",
  "version": "0.1.0",
  "description": "QQbot adapter for Chat SDK",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "peerDependencies": {
    "chat": "catalog:"
  },
  "dependencies": {
    "@chat-adapter/shared": "catalog:"
  },
  "devDependencies": {
    "chat": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "chat-sdk",
    "chat-adapter",
    "qqbot"
  ],
  "license": "MIT"
}
